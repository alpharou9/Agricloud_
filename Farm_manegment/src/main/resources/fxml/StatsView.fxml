<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="20" alignment="CENTER" prefWidth="600" prefHeight="500"
      style="-fx-background-color: #f4f7f0; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.shahed.controller.StatsController">

    <Label text="Land Allocation by Farm Type"
           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3e4a2e;"/>

    <PieChart fx:id="landPieChart" legendSide="BOTTOM" VBox.vgrow="ALWAYS" />

    <Button text="Close" onAction="#handleClose"
            style="-fx-background-color: #3e4a2e; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 8 20;"/>
</VBox>