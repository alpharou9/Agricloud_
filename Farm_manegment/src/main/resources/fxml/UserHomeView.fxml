<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0" styleClass="root" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.shahed.controller.UserHomeController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color: #2D5A27; -fx-padding: 30 15 15 15;">
                    <children>
                        <Label text="AGRICLOUD" textFill="WHITE">
                            <font><Font name="System Bold" size="22.0" /></font>
                            <VBox.margin><Insets bottom="30.0" /></VBox.margin>
                        </Label>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-cursor: hand;" text="🏠  Home" />
                        <Button onAction="#switchToDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="📊  Dashboard" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Separator opacity="0.2" />
                        <Label text="Logged in as Admin" textFill="#b2ceae">
                            <font><Font size="12.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="20.0" style="-fx-padding: 25; -fx-background-color: #f4f4f4;" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2D5A27;" text="My Farm Inventory" />
                                <Region HBox.hgrow="ALWAYS" />

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Type:" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <ComboBox fx:id="filterTypeCombo" onAction="#handleFilterAndSort" prefWidth="150.0" promptText="All Types"
                                                  style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5;" />
                                    </children>
                                </HBox>

                                <Button onAction="#handleSortDate" prefHeight="35.0" style="-fx-background-color: #3e4a2e; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" text="Sort by Date ↑↓" />
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <FlowPane fx:id="farmContainer" hgap="20.0" style="-fx-padding: 10;" vgap="20.0" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>