<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0" styleClass="root" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.shahed.controller.FarmController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color: #2D5A27; -fx-padding: 30 15 15 15;">
                    <children>
                        <Label text="AGRICLOUD" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="30.0" />
                            </VBox.margin>
                        </Label>

                        <Button fx:id="homeBtn" onAction="#handleHomeNavigation" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14;" text="🏠  Home" />

                        <Button fx:id="dashBtn" onAction="#handleDashboardNavigation" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0"
                                style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;" text="📊  Dashboard" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Separator opacity="0.2" />
                        <Label text="Logged in as Admin" textFill="#b2ceae">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox fx:id="mainContentArea" spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Label styleClass="title-label" text="Farm &amp; Fields Inventory">
                                    <font>
                                        <Font name="System Bold" size="32.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="searchTypeCombo" prefWidth="150.0" style="-fx-background-radius: 15;" />
                                        <Button onAction="#handleSortByName" styleClass="btn-dark" text="Sort A-Z" />
                                        <Button onAction="#handleSortByDate" styleClass="btn-dark" text="Sort by Date ↑↓" />
                                        <Button onAction="#showStatistics" styleClass="btn-dark" text="📊 Statistics" />
                                        <Button onAction="#handleExportPDF" styleClass="btn-dark" text="Detailed Export" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <TableView fx:id="farmTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
                                <TableColumn fx:id="colLocation" prefWidth="150.0" text="Location" />
                                <TableColumn fx:id="colLat" prefWidth="100.0" text="Latitude" />
                                <TableColumn fx:id="colLong" prefWidth="100.0" text="Longitude" />
                                <TableColumn fx:id="colArea" prefWidth="80.0" text="Area (ha)" />
                                <TableColumn fx:id="colType" prefWidth="120.0" text="Type" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                                <TableColumn fx:id="colDescription" prefWidth="150.0" text="Description" />
                                <TableColumn fx:id="colActions" prefWidth="260.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER">
                            <children>
                                <Button fx:id="addMainBtn" onAction="#showAddForm" prefHeight="45.0" prefWidth="250.0" styleClass="btn-dark" text="+ Add New Farm" />
                            </children>
                        </HBox>

                        <VBox fx:id="formContainer" managed="false" spacing="15.0" visible="false" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #e8f0fe; -fx-padding: 15; -fx-background-radius: 12;">
                                    <children>
                                        <ImageView fx:id="weatherIcon" fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true" />
                                        <Label fx:id="weatherLabel" text="Weather information loading..." style="-fx-font-weight: bold; -fx-text-fill: #1a73e8; -fx-font-size: 16px;" />
                                    </children>
                                </HBox>

                                <GridPane hgap="15.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <TextField fx:id="nameField" promptText="Enter Farm Name" />
                                        <HBox spacing="5.0" GridPane.columnIndex="1">
                                            <children>
                                                <TextField fx:id="locationField" promptText="Location Address" HBox.hgrow="ALWAYS" />
                                                <Button onAction="#openMapPopup" text="📍" />
                                            </children>
                                        </HBox>
                                        <TextField fx:id="latField" promptText="Latitude" GridPane.rowIndex="1" />
                                        <TextField fx:id="longField" promptText="Longitude" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <TextField fx:id="areaField" promptText="Area (hectares)" GridPane.rowIndex="2" />
                                        <ComboBox fx:id="typeCombo" prefWidth="600.0" promptText="Farm Category" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>
                                <TextArea fx:id="descriptionField" prefHeight="80.0" promptText="Add a brief description..." />

                                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                    <children>
                                        <Button onAction="#handleCancelAction" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 10;" text="Discard" />
                                        <Button onAction="#handleSaveAction" styleClass="btn-dark" text="Confirm &amp; Save" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>