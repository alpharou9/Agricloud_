<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="20" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.shahed.controller.FarmController"
      style="-fx-background-color: #e1e9d3; -fx-padding: 30;">

    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <HBox spacing="20" alignment="CENTER">
        <Label text="Farm Dashboard" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3e4a2e;"/>
        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Search Type:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="searchTypeCombo" prefWidth="150" style="-fx-background-radius: 15;"/>

        <Button text="Sort A-Z" onAction="#handleSortByName"
                style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15;"/>
    </HBox>

    <TableView fx:id="farmTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
            <TableColumn fx:id="colName" text="Farm Name"/>
            <TableColumn fx:id="colLocation" text="Location"/>
            <TableColumn fx:id="colLat" text="Lat"/>
            <TableColumn fx:id="colLong" text="Long"/>
            <TableColumn fx:id="colArea" text="Area"/>
            <TableColumn fx:id="colType" text="Type"/>
            <TableColumn fx:id="colStatus" text="Status"/>
            <TableColumn fx:id="colDesc" text="Description"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="240"/>
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>

    <VBox fx:id="formContainer" visible="false" managed="false" spacing="10"
          style="-fx-background-color: #ced7bd; -fx-background-radius: 20; -fx-padding: 15; -fx-border-color: #a07a44; -fx-border-radius: 20;">
        <GridPane hgap="10" vgap="10" alignment="CENTER">
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Farm Name"/><TextField fx:id="nameField"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Location"/><TextField fx:id="locationField"/>
            </VBox>
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Area"/><TextField fx:id="areaField"/>
            </VBox>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Latitude"/><TextField fx:id="latField"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Longitude"/><TextField fx:id="longField"/>
            </VBox>
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Label text="Farm Type"/><ComboBox fx:id="typeCombo" prefWidth="200"/>
            </VBox>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="3">
                <Label text="Description"/><TextArea fx:id="descriptionField" prefHeight="50"/>
            </VBox>
        </GridPane>
        <HBox spacing="15" alignment="CENTER">
            <Button text="Save" onAction="#handleSaveAction" styleClass="button-save" prefWidth="100"/>
            <Button text="Cancel" onAction="#handleCancelAction" style="-fx-background-radius: 15;" prefWidth="100"/>
        </HBox>
    </VBox>

    <Button fx:id="addMainBtn" text="+ Add Farm" onAction="#showAddForm"
            style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 25;"/>
</VBox>