<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.shahed.controller.FieldController"
      style="-fx-background-color: #FFFFFF; -fx-padding: 30;">

    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <Button text="← Back to Farms" onAction="#handleBack"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 15; -fx-font-weight: bold;"/>

        <Label fx:id="headerLabel" text="Fields Inventory"
               style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
    </HBox>

    <TableView fx:id="fieldTable" VBox.vgrow="ALWAYS" style="-fx-selection-bar: #4CAF50; -fx-background-color: white; -fx-border-color: #A5D6A7;">
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colName" text="Field Name"/>
            <TableColumn fx:id="colArea" text="Area (ha)"/>
            <TableColumn fx:id="colSoil" text="Soil Type"/>
            <TableColumn fx:id="colCrop" text="Crop Type"/>
            <TableColumn fx:id="colCoords" text="GPS Coordinates"/>
            <TableColumn fx:id="colStatus" text="Status"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="200"/>
        </columns>
    </TableView>

    <Button fx:id="addMainBtn" text="+ Add New Field" onAction="#showAddFieldForm"
            style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 16; -fx-background-radius: 20; -fx-padding: 10 30;"/>

    <VBox fx:id="fieldFormContainer" spacing="15" visible="false" managed="false"
          style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20; -fx-border-color: #2E7D32; -fx-border-width: 2; -fx-border-radius: 20;">
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="120" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="400" />
            </columnConstraints>

            <Label text="Field Name:" GridPane.rowIndex="0" style="-fx-text-fill: black;"/>
            <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-border-color: #81C784;"/>

            <Label text="Area (ha):" GridPane.rowIndex="1" style="-fx-text-fill: black;"/>
            <TextField fx:id="areaField" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-border-color: #81C784;"/>

            <Label text="Soil Type:" GridPane.rowIndex="2" style="-fx-text-fill: black;"/>
            <ComboBox fx:id="soilCombo" prefWidth="1000" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-border-color: #81C784;"/>

            <Label text="Crop Type:" GridPane.rowIndex="3" style="-fx-text-fill: black;"/>
            <ComboBox fx:id="cropCombo" prefWidth="1000" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-border-color: #81C784;"/>

            <Label text="Coordinates:" GridPane.rowIndex="4" style="-fx-text-fill: black;"/>
            <TextField fx:id="coordsField" editable="false" GridPane.rowIndex="4" GridPane.columnIndex="1"
                       style="-fx-background-color: #F5F5F5; -fx-text-fill: #666; -fx-border-color: #CCC;"/>

            <Label text="Status:" GridPane.rowIndex="5" style="-fx-text-fill: black;"/>
            <ComboBox fx:id="statusCombo" prefWidth="1000" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-border-color: #81C784;"/>
        </GridPane>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <children>
                <Button text="Cancel" onAction="#handleCancelAction"
                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 10;"/>
                <Button text="Save Field" onAction="#handleSaveField"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>
            </children>
        </HBox>
    </VBox>
</VBox>