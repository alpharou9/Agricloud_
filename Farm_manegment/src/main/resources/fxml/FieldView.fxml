<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>

<VBox spacing="20" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.shahed.controller.FieldController"
      style="-fx-background-color: #e1e9d3; -fx-padding: 40;">

    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <Button text="Back to farms" onAction="#handleBack"
                style="-fx-background-radius: 20; -fx-border-color: #a07a44; -fx-background-color: transparent; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="headerLabel" text="Fields" style="-fx-font-size: 35; -fx-font-weight: bold; -fx-text-fill: #3e4a2e;"/>
        <Region HBox.hgrow="ALWAYS"/>

        <Button text="Sort A-Z" onAction="#handleSortByName"
                style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 8 15;"/>
    </HBox>

    <TableView fx:id="fieldTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colName" text="Name"/>
            <TableColumn fx:id="colArea" text="Area (ha)"/>
            <TableColumn fx:id="colSoil" text="Soil Type"/>
            <TableColumn fx:id="colCrop" text="Crop Type"/>
            <TableColumn fx:id="colCoords" text="Coordinates"/>
            <TableColumn fx:id="colStatus" text="Status"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="180"/>
        </columns>
    </TableView>

    <VBox fx:id="fieldFormContainer" visible="false" managed="false" spacing="15" alignment="CENTER"
          style="-fx-background-color: #ced7bd; -fx-background-radius: 30; -fx-padding: 20; -fx-border-color: #a07a44; -fx-border-radius: 30;">
        <GridPane hgap="20" vgap="10" alignment="CENTER">
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Field Name"/><TextField fx:id="nameField" promptText="e.g., North Sector"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Area (ha)"/><TextField fx:id="areaField" promptText="e.g., 12.5"/>
            </VBox>
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Coordinates"/><TextField fx:id="coordsField" promptText="Lat, Long"/>
            </VBox>
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Status"/><ComboBox fx:id="statusCombo" prefWidth="200" promptText="Select Status"/>
            </VBox>
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Soil type"/><ComboBox fx:id="soilCombo" prefWidth="200" promptText="Select Soil"/>
            </VBox>
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Label text="Crop type"/><ComboBox fx:id="cropCombo" prefWidth="200" promptText="Select Crop"/>
            </VBox>
        </GridPane>
        <HBox spacing="20" alignment="CENTER">
            <Button text="Save Field" onAction="#handleSaveField" styleClass="button-save" prefWidth="150" prefHeight="40"/>
            <Button text="Cancel" onAction="#handleCancelAction"
                    style="-fx-background-color: #888; -fx-text-fill: white; -fx-background-radius: 25;" prefWidth="150" prefHeight="40"/>
        </HBox>
    </VBox>

    <Button fx:id="addMainBtn" text="+ Add a Field" onAction="#showAddFieldForm"
            style="-fx-background-color: transparent; -fx-border-color: #a07a44; -fx-border-width: 3; -fx-border-radius: 25; -fx-font-size: 20; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 40;"/>
</VBox>