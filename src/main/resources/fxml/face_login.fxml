<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="esprit.farouk.controllers.FaceLoginController"
      spacing="20"
      alignment="CENTER"
      styleClass="login-container"
      prefWidth="800"
      prefHeight="650">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <!-- App Title -->
    <Label text="AgriCloud" styleClass="app-title"/>
    <Label text="Face Recognition Login" styleClass="app-subtitle"/>

    <!-- Camera Preview Card -->
    <VBox spacing="15" alignment="CENTER"
          styleClass="login-card"
          prefWidth="680"
          prefHeight="480">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Camera Preview -->
        <ImageView fx:id="cameraPreview"
                   fitWidth="640"
                   fitHeight="480"
                   preserveRatio="true"
                   styleClass="camera-frame"/>

        <!-- Status Label -->
        <Label fx:id="statusLabel"
               text="Position your face in the camera"
               styleClass="status-label"
               wrapText="true"/>

        <!-- Progress Indicator -->
        <ProgressIndicator fx:id="progressIndicator"
                          visible="false"
                          managed="false"/>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="scanButton"
                text="Scan Face"
                onAction="#handleScanFace"
                styleClass="primary-button"
                prefWidth="150"
                prefHeight="45"
                defaultButton="true">
            <graphic>
                <Label text="👤" style="-fx-font-size: 20;"/>
            </graphic>
        </Button>

        <Button text="Use Password"
                onAction="#handleUsePassword"
                styleClass="secondary-button"
                prefWidth="150"
                prefHeight="45"/>
    </HBox>

    <!-- Help Text -->
    <Label text="Make sure your face is clearly visible and well-lit"
           styleClass="help-text"
           wrapText="true"/>

</VBox>
